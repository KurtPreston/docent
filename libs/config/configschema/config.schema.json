{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/config.schema.json",
  "title": "docent userdata config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ai": {
      "$ref": "#/$defs/ai"
    },
    "session_manager": {
      "$ref": "#/$defs/session_manager"
    },
    "directives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/directiveItem"
      }
    },
    "execution_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/executionMode"
      }
    },
    "automations": {
      "type": "array",
      "description": "IFTTT-style rules that react to signals, state transitions, or a schedule.",
      "items": {
        "$ref": "#/$defs/automationRule"
      }
    },
    "output_dir": {
      "type": "string",
      "description": "Directory where docent-reporter writes generated markdown. Supports a leading ~ for the home directory. Defaults to ~/docent."
    }
  },
  "$defs": {
    "automationRule": {
      "type": "object",
      "required": ["id", "enabled", "trigger", "actions"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "trigger": { "$ref": "#/$defs/automationTrigger" },
        "conditions": { "$ref": "#/$defs/automationConditions" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/automationAction" }
        }
      }
    },
    "automationTrigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["signal", "transition", "schedule"]
        },
        "source": { "type": "string" },
        "kind": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "match": { "$ref": "#/$defs/automationMatch" },
        "when": { "$ref": "#/$defs/automationWhen" },
        "cron": {
          "type": "string",
          "description": "5-field cron expression (min hour dom month dow)"
        },
        "at": {
          "type": "string",
          "description": "Daily time-of-day HH:MM (local)",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "weekday": {
          "type": "string",
          "description": "Optional weekday name restricting 'at' (e.g. friday)"
        }
      }
    },
    "automationMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string", "description": "Regex matched against Title + Summary" },
        "ticket_key": {
          "type": "boolean",
          "description": "Extract a known JIRA ticket key from the signal text"
        },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "automationWhen": {
      "type": "object",
      "required": ["field"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },
    "automationConditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "self": { "type": "boolean" },
        "repos": { "type": "array", "items": { "type": "string" } },
        "dedupe_key": { "type": "string" },
        "cooldown": {
          "type": "string",
          "description": "Duration suppressing re-fires (e.g. 30m)"
        }
      }
    },
    "automationAction": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["webhook", "shell", "jira-comment", "slack-post", "agent", "agent-inline", "report", "open"]
        },
        "url": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": { "type": "string" },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string" },
        "issue": { "type": "string" },
        "channel": { "type": "string" },
        "provider": { "type": "string" },
        "workdir": { "type": "string", "enum": ["worktree", "open_path"] },
        "prompt": { "type": "string" },
        "post": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "mode": { "type": "string" },
        "deliver": { "type": "string", "enum": ["file", "slack", "webhook"] },
        "out_path": { "type": "string" },
        "days": { "type": "integer", "minimum": 1 }
      }
    },
    "executionMode": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string"
        },
        "lookback": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["days", "previous-weekday"]
            },
            "days": {
              "type": "integer",
              "minimum": 1
            }
          },
          "oneOf": [
            {
              "properties": {
                "kind": { "const": "days" }
              },
              "required": ["days"]
            },
            {
              "properties": {
                "kind": { "const": "previous-weekday" }
              },
              "not": { "required": ["days"] }
            }
          ]
        },
        "formatter": {
          "type": "string",
          "enum": ["repo-chronological", "json-signal-list"]
        },
        "prompt": {
          "type": "object",
          "required": ["instruction"],
          "additionalProperties": false,
          "properties": {
            "instruction": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "scope": {
          "type": "string",
          "enum": ["self", "involved", "all"]
        },
        "collect": {
          "type": "string",
          "enum": ["events", "state", "both"],
          "description": "Which collection capabilities to run: events (timeline), state (current snapshot), or both"
        },
        "collectors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "rule-based"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-docent-prompt": "Activity formatter",
              "x-docent-default": "repo-chronological",
              "x-docent-setup-skip-prompt": true
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        },
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "ollama"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-docent-prompt": "Activity formatter",
              "x-docent-default": "repo-chronological",
              "x-docent-setup-skip-prompt": true
            },
            "ollama": {
              "type": "object",
              "properties": {
                "base_url": {
                  "type": "string",
                  "x-docent-prompt": "Ollama server URL",
                  "x-docent-default": "http://127.0.0.1:11434",
                  "x-docent-validator": "url"
                },
                "model": {
                  "type": "string",
                  "x-docent-prompt": "Ollama model name",
                  "x-docent-default": "llama3"
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        },
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "cursor"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-docent-prompt": "Activity formatter",
              "x-docent-default": "repo-chronological",
              "x-docent-setup-skip-prompt": true
            },
            "cursor": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string",
                  "x-docent-prompt": "cursor-agent command",
                  "x-docent-default": "cursor-agent",
                  "x-docent-setup-skip-prompt": true
                },
                "args": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-docent-setup-skip-prompt": true
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        },
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "claude"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-docent-prompt": "Activity formatter",
              "x-docent-default": "repo-chronological",
              "x-docent-setup-skip-prompt": true
            },
            "claude": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string",
                  "x-docent-prompt": "claude command",
                  "x-docent-default": "claude",
                  "x-docent-setup-skip-prompt": true
                },
                "args": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-docent-prompt": "Extra claude args (optional, comma-separated)",
                  "x-docent-setup-skip-prompt": true
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        }
      ]
    },
    "session_manager": {
      "type": "object",
      "additionalProperties": false,
      "description": "Selects how docent lists and opens editor windows. Omit entirely for no session manager (no session column, no clickable links).",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["cursor", "wsm"],
          "x-docent-prompt": "Session manager (cursor or wsm)",
          "x-docent-default": "cursor"
        },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string",
              "x-docent-prompt": "Cursor CLI command",
              "x-docent-default": "cursor",
              "x-docent-setup-skip-prompt": true
            },
            "host": {
              "type": "string",
              "x-docent-prompt": "SSH host alias for remote deep links (defaults to docentd sshHost)",
              "x-docent-setup-skip-prompt": true
            },
            "write_color": {
              "type": "boolean",
              "default": true,
              "x-docent-default": true,
              "x-docent-setup-skip-prompt": true
            },
            "poll_status": {
              "type": "boolean",
              "default": true,
              "description": "Poll cursor --status to list live windows. Set false on macOS to avoid Dock bounce.",
              "x-docent-default": true,
              "x-docent-setup-skip-prompt": true
            }
          }
        },
        "wsm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "base_url": {
              "type": "string",
              "x-docent-prompt": "wsm HTTP base URL",
              "x-docent-default": "http://127.0.0.1:39788",
              "x-docent-validator": "url"
            },
            "token": {
              "type": "string",
              "x-docent-secret": true,
              "x-docent-prompt": "wsm bearer token (optional)"
            }
          }
        }
      }
    },
    "directiveBase": {
      "type": "object",
      "required": ["id", "name", "collector", "enabled"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "x-docent-setup-skip-prompt": true
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "x-docent-setup-skip-prompt": true
        },
        "collector": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "code_home": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "state": {
          "$ref": "#/$defs/modeConfig"
        },
        "events": {
          "$ref": "#/$defs/modeConfig"
        }
      },
      "additionalProperties": false
    },
    "poll": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interval": {
          "type": "string",
          "description": "Background poll cadence (e.g. 15m, 1h). Empty or 0 disables background polling."
        },
        "on_request": {
          "type": "boolean",
          "description": "Collect inline when a page is requested (for fast, high-priority sources)."
        },
        "on_load": {
          "type": "boolean",
          "description": "Collect once at daemon startup."
        }
      }
    },
    "modeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "poll": {
          "$ref": "#/$defs/poll"
        },
        "query": {
          "type": "string",
          "description": "Overrides config.query for this collection mode (e.g. a state-view JQL)."
        },
        "lookback": {
          "type": "string",
          "description": "Initial/first-poll window for an events unit (e.g. 7d, 1h). Ignored for state units."
        }
      }
    },
    "directiveItem": {
      "allOf": [
        {
          "$ref": "#/$defs/directiveBase"
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/directive.local-git"
            },
            {
              "$ref": "#/$defs/directive.github"
            },
            {
              "$ref": "#/$defs/directive.github-enterprise"
            },
            {
              "$ref": "#/$defs/directive.gitea"
            },
            {
              "$ref": "#/$defs/directive.jira"
            },
            {
              "$ref": "#/$defs/directive.google-calendar"
            },
            {
              "$ref": "#/$defs/directive.slack"
            },
            {
              "$ref": "#/$defs/directive.webhook"
            },
            {
              "$ref": "#/$defs/directive.wsm"
            }
          ]
        }
      ]
    },
    "directive.local-git": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "local-git",
          "x-docent-default-id": "local-git",
          "x-docent-display-name": "Local git repos"
        },
        "code_home": {
          "type": "string",
          "x-docent-prompt": "Directory containing git repos (immediate children scanned)",
          "x-docent-validator": "dir-exists"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "x-docent-validator": "dir-exists"
          },
          "x-docent-prompt": "Explicit repo paths (optional if code_home is set)"
        }
      },
      "required": ["collector"],
      "oneOf": [
        {
          "required": ["code_home"],
          "properties": {
            "code_home": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["paths"],
          "properties": {
            "paths": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "directive.github": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "github",
          "x-docent-default-id": "github",
          "x-docent-display-name": "GitHub activity"
        },
        "target": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "x-docent-prompt": "GitHub username (leave empty for authenticated user)",
              "x-docent-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "x-docent-prompt": "GitHub host URL (default https://github.com)",
              "x-docent-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-docent-prompt": "Comma-separated owner/repo list to include when scope=all",
              "x-docent-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "x-docent-secret": true,
              "x-docent-default": "DOCENT_GITHUB_TOKEN",
              "x-docent-prompt": "Env var for GitHub token (optional; gh auth also works)"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector"]
    },
    "directive.github-enterprise": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "github-enterprise",
          "x-docent-default-id": "github-enterprise",
          "x-docent-display-name": "GitHub Enterprise activity"
        },
        "target": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "x-docent-prompt": "GitHub Enterprise username (leave empty for authenticated user)",
              "x-docent-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-docent-prompt": "GitHub Enterprise base URL",
              "x-docent-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-docent-prompt": "Comma-separated owner/repo list to include when scope=all",
              "x-docent-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "x-docent-secret": true,
              "x-docent-default": "DOCENT_GITHUB_TOKEN",
              "x-docent-prompt": "Env var for GitHub token (optional; gh auth also works)"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config"]
    },
    "directive.gitea": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "gitea",
          "x-docent-default-id": "gitea",
          "x-docent-display-name": "Gitea"
        },
        "target": {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string",
              "x-docent-prompt": "User or organization (leave empty for authenticated user)",
              "x-docent-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-docent-prompt": "Gitea base URL",
              "x-docent-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-docent-prompt": "Comma-separated owner/repo (or bare owner) list to include when scope=all",
              "x-docent-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "minLength": 1,
              "x-docent-secret": true,
              "x-docent-default": "DOCENT_GITEA_TOKEN",
              "x-docent-prompt": "Env var name for Gitea API token"
            }
          },
          "required": ["token"],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config", "credential_refs"]
    },
    "directive.jira": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "jira",
          "x-docent-default-id": "jira",
          "x-docent-display-name": "Jira"
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-docent-prompt": "Jira site base URL",
              "x-docent-validator": "url"
            },
            "query": {
              "type": "string",
              "x-docent-prompt": "Optional JQL filter (default: issues you assign/report/watch)"
            },
            "followed_projects": {
              "type": "string",
              "x-docent-prompt": "Comma-separated Jira project keys to include when scope=all",
              "x-docent-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "pat": {
              "type": "string",
              "minLength": 1,
              "x-docent-secret": true,
              "x-docent-default": "DOCENT_JIRA_PAT",
              "x-docent-prompt": "Env var for Jira Personal Access Token"
            }
          },
          "required": ["pat"],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config", "credential_refs"]
    },
    "directive.google-calendar": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "google-calendar",
          "x-docent-default-id": "google-calendar",
          "x-docent-display-name": "Google Calendar (iCal)"
        },
        "config": {
          "type": "object",
          "properties": {
            "ical_url": {
              "type": "string",
              "minLength": 1,
              "x-docent-prompt": "Secret iCal URL (only if not using env)"
            },
            "url": {
              "type": "string",
              "minLength": 1,
              "x-docent-prompt": "Alternate: calendar URL key url"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "ical_url": {
