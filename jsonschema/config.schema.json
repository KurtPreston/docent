{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slakkr.local/config.schema.json",
  "title": "slakkr-ai userdata config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ai": {
      "$ref": "#/$defs/ai"
    },
    "directives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/directiveItem"
      }
    },
    "execution_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/executionMode"
      }
    }
  },
  "$defs": {
    "executionMode": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string"
        },
        "lookback": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["days", "previous-weekday"]
            },
            "days": {
              "type": "integer",
              "minimum": 1
            }
          },
          "oneOf": [
            {
              "properties": {
                "kind": { "const": "days" }
              },
              "required": ["days"]
            },
            {
              "properties": {
                "kind": { "const": "previous-weekday" }
              },
              "not": { "required": ["days"] }
            }
          ]
        },
        "formatter": {
          "type": "string",
          "enum": ["repo-chronological", "json-signal-list"]
        },
        "prompt": {
          "type": "object",
          "required": ["instruction"],
          "additionalProperties": false,
          "properties": {
            "instruction": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "scope": {
          "type": "string",
          "enum": ["self", "involved", "all"]
        },
        "collectors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "rule-based"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-slakkr-prompt": "Activity formatter",
              "x-slakkr-default": "repo-chronological",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        },
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "ollama"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-slakkr-prompt": "Activity formatter",
              "x-slakkr-default": "repo-chronological",
              "x-slakkr-setup-skip-prompt": true
            },
            "ollama": {
              "type": "object",
              "properties": {
                "base_url": {
                  "type": "string",
                  "x-slakkr-prompt": "Ollama server URL",
                  "x-slakkr-default": "http://127.0.0.1:11434",
                  "x-slakkr-validator": "url"
                },
                "model": {
                  "type": "string",
                  "x-slakkr-prompt": "Ollama model name",
                  "x-slakkr-default": "llama3"
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        },
        {
          "properties": {
            "provider": {
              "type": "string",
              "const": "cursor"
            },
            "activity_formatter": {
              "type": "string",
              "enum": ["repo-chronological", "json-signal-list"],
              "default": "repo-chronological",
              "x-slakkr-prompt": "Activity formatter",
              "x-slakkr-default": "repo-chronological",
              "x-slakkr-setup-skip-prompt": true
            },
            "cursor": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string",
                  "x-slakkr-prompt": "cursor-agent command",
                  "x-slakkr-default": "cursor-agent",
                  "x-slakkr-setup-skip-prompt": true
                },
                "args": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-slakkr-setup-skip-prompt": true
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["provider"],
          "additionalProperties": false
        }
      ]
    },
    "directiveBase": {
      "type": "object",
      "required": ["id", "name", "collector", "enabled"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "x-slakkr-setup-skip-prompt": true
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "x-slakkr-setup-skip-prompt": true
        },
        "collector": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "code_home": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "directiveItem": {
      "allOf": [
        {
          "$ref": "#/$defs/directiveBase"
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/directive.local-git"
            },
            {
              "$ref": "#/$defs/directive.github"
            },
            {
              "$ref": "#/$defs/directive.github-enterprise"
            },
            {
              "$ref": "#/$defs/directive.gitea"
            },
            {
              "$ref": "#/$defs/directive.jira"
            },
            {
              "$ref": "#/$defs/directive.google-calendar"
            },
            {
              "$ref": "#/$defs/directive.slack"
            }
          ]
        }
      ]
    },
    "directive.local-git": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "local-git",
          "x-slakkr-default-id": "local-git",
          "x-slakkr-display-name": "Local git repos"
        },
        "code_home": {
          "type": "string",
          "x-slakkr-prompt": "Directory containing git repos (immediate children scanned)",
          "x-slakkr-validator": "dir-exists"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "x-slakkr-validator": "dir-exists"
          },
          "x-slakkr-prompt": "Explicit repo paths (optional if code_home is set)"
        }
      },
      "required": ["collector"],
      "oneOf": [
        {
          "required": ["code_home"],
          "properties": {
            "code_home": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["paths"],
          "properties": {
            "paths": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "directive.github": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "github",
          "x-slakkr-default-id": "github",
          "x-slakkr-display-name": "GitHub activity"
        },
        "target": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "x-slakkr-prompt": "GitHub username (leave empty for authenticated user)",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "x-slakkr-prompt": "GitHub host URL (default https://github.com)",
              "x-slakkr-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-slakkr-prompt": "Comma-separated owner/repo list to include when scope=all",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_GITHUB_TOKEN",
              "x-slakkr-prompt": "Env var for GitHub token (optional; gh auth also works)"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector"]
    },
    "directive.github-enterprise": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "github-enterprise",
          "x-slakkr-default-id": "github-enterprise",
          "x-slakkr-display-name": "GitHub Enterprise activity"
        },
        "target": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "x-slakkr-prompt": "GitHub Enterprise username (leave empty for authenticated user)",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-prompt": "GitHub Enterprise base URL",
              "x-slakkr-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-slakkr-prompt": "Comma-separated owner/repo list to include when scope=all",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_GITHUB_TOKEN",
              "x-slakkr-prompt": "Env var for GitHub token (optional; gh auth also works)"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config"]
    },
    "directive.gitea": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "gitea",
          "x-slakkr-default-id": "gitea",
          "x-slakkr-display-name": "Gitea"
        },
        "target": {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string",
              "x-slakkr-prompt": "User or organization (leave empty for authenticated user)",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-prompt": "Gitea base URL",
              "x-slakkr-validator": "url"
            },
            "followed_repos": {
              "type": "string",
              "x-slakkr-prompt": "Comma-separated owner/repo (or bare owner) list to include when scope=all",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_GITEA_TOKEN",
              "x-slakkr-prompt": "Env var name for Gitea API token"
            }
          },
          "required": ["token"],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config", "credential_refs"]
    },
    "directive.jira": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "jira",
          "x-slakkr-default-id": "jira",
          "x-slakkr-display-name": "Jira"
        },
        "config": {
          "type": "object",
          "properties": {
            "base_url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-prompt": "Jira site base URL",
              "x-slakkr-validator": "url"
            },
            "query": {
              "type": "string",
              "x-slakkr-prompt": "Optional JQL filter (default: issues you assign/report/watch)"
            },
            "followed_projects": {
              "type": "string",
              "x-slakkr-prompt": "Comma-separated Jira project keys to include when scope=all",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "required": ["base_url"],
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "pat": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_JIRA_PAT",
              "x-slakkr-prompt": "Env var for Jira Personal Access Token"
            }
          },
          "required": ["pat"],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "config", "credential_refs"]
    },
    "directive.google-calendar": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "google-calendar",
          "x-slakkr-default-id": "google-calendar",
          "x-slakkr-display-name": "Google Calendar (iCal)"
        },
        "config": {
          "type": "object",
          "properties": {
            "ical_url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-prompt": "Secret iCal URL (only if not using env)"
            },
            "url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-prompt": "Alternate: calendar URL key url"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "ical_url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_GOOGLE_CALENDAR_ICAL_URL",
              "x-slakkr-prompt": "Env var holding secret iCal URL"
            },
            "url": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_GOOGLE_CALENDAR_URL",
              "x-slakkr-prompt": "Env var holding calendar URL (alias)"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector"],
      "oneOf": [
        {
          "properties": {
            "config": {
              "type": "object",
              "required": ["ical_url"],
              "properties": {
                "ical_url": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["config"]
        },
        {
          "properties": {
            "config": {
              "type": "object",
              "required": ["url"],
              "properties": {
                "url": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["config"]
        },
        {
          "properties": {
            "credential_refs": {
              "type": "object",
              "required": ["ical_url"],
              "properties": {
                "ical_url": {
                  "type": "string",
                  "minLength": 1,
                  "x-slakkr-secret": true,
                  "x-slakkr-default": "SLAKKR_GOOGLE_CALENDAR_ICAL_URL",
                  "x-slakkr-prompt": "Env var holding secret iCal URL"
                }
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": ["credential_refs"]
        },
        {
          "properties": {
            "credential_refs": {
              "type": "object",
              "required": ["url"],
              "properties": {
                "url": {
                  "type": "string",
                  "minLength": 1,
                  "x-slakkr-secret": true,
                  "x-slakkr-default": "SLAKKR_GOOGLE_CALENDAR_URL",
                  "x-slakkr-prompt": "Env var holding calendar URL (alias)"
                }
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": ["credential_refs"]
        }
      ]
    },
    "directive.slack": {
      "type": "object",
      "properties": {
        "collector": {
          "type": "string",
          "const": "slack",
          "x-slakkr-default-id": "slack",
          "x-slakkr-display-name": "Slack"
        },
        "config": {
          "type": "object",
          "properties": {
            "followed_channels": {
              "type": "string",
              "x-slakkr-prompt": "Comma-separated channel names (#team) or IDs to include when scope=all",
              "x-slakkr-setup-skip-prompt": true
            },
            "user_id": {
              "type": "string",
              "x-slakkr-prompt": "Override Slack user ID (leave empty to resolve via auth.test)",
              "x-slakkr-setup-skip-prompt": true
            },
            "history_concurrency": {
              "type": "string",
              "pattern": "^[0-9]+$",
              "x-slakkr-prompt": "How many DM/MPIM history requests to run in parallel (default 4, max 16)",
              "x-slakkr-setup-skip-prompt": true
            },
            "dm_discovery": {
              "type": "string",
              "x-slakkr-prompt": "DM discovery: 'auto' (default) finds active DMs via search; 'off' polls every DM",
              "x-slakkr-setup-skip-prompt": true
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "credential_refs": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "minLength": 1,
              "x-slakkr-secret": true,
              "x-slakkr-default": "SLAKKR_SLACK_TOKEN",
              "x-slakkr-prompt": "Env var for Slack user OAuth token (xoxp-...)"
            }
          },
          "required": ["token"],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["collector", "credential_refs"]
    }
  }
}
