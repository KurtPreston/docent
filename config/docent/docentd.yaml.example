port: 39787
refreshSec: 30
wsmUrl: http://127.0.0.1:39788

# Shared secret (optional). Set this (or the DOCENT_TOKEN env var, which wins) to
# require an "Authorization: Bearer <token>" header on every data endpoint
# (/sessions, /api/*). /health and the static dashboard shell stay open.
# IMPORTANT: setting a token also makes docentd bind ALL interfaces (0.0.0.0) by
# default, so it is reachable off the loopback. With no token docentd stays
# bound to 127.0.0.1 and serves openly (localhost only).
# token: change-me-to-a-long-random-string

# Bind interface override. Leave unset to use the token-gated default above.
# Set to 127.0.0.1 to force loopback-only even with a token; set to a specific
# address to bind one interface.
# bindHost: 0.0.0.0

# Ticket-key matching (branch names, PR/commit titles, JIRA issue keys, etc.).
# ticketProjects restricts matching to these JIRA project keys, so generic
# hyphenated tokens like "PR-7373" or "release-2026" don't false-match as
# tickets. The engine also auto-adds any project key observed on collected
# jira issues (including a jira directive's config.followed_projects), so
# this is usually only needed when no jira directive is configured at all.
# ticketProjects: [SALSA, JASPER]
#
# ticketPattern fully overrides ticket-key matching with a custom regex
# (first capture group is the key); leave unset to use ticketProjects /
# the auto-detected projects, or a fully generic [a-z]+-\d+ pattern.
# ticketPattern: "^([A-Z]+-\\d+)"

# Directives, optional ai, and secrets live alongside this file:
#   ~/.config/docent/config.yaml   unified app config (directives + optional ai)
#   ~/.config/docent/.env          credential_refs secrets
