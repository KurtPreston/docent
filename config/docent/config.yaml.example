# yaml-language-server: $schema=../../jsonschema/config.schema.json
# Unified docent config. Copy to ~/.config/docent/config.yaml and edit.
# Directives drive collectors; ai is optional (for future dashboard features).

# ai:
#   provider: ollama
#   ollama:
#     base_url: http://127.0.0.1:11434
#     model: qwen3

# session_manager selects how the dashboard opens/lists editor windows.
# Omit it entirely for no session column and no clickable links.
#   provider: cursor        # or: wsm
#   cursor:
#     command: cursor       # Cursor CLI binary
#     host: my-dev-box      # ssh alias for remote deep links (defaults to sshHost)
#     write_color: true     # sync work-item color into .vscode/settings.json (default true)
# session_manager:
#   provider: wsm
#   wsm:
#     base_url: http://127.0.0.1:39788

directives:
  - id: local-git-status
    name: git repo working trees
    collector: local-git
    enabled: true
    code_home: /Users/me/Code

  # - id: github-activity
  #   name: GitHub Activity
  #   collector: github
  #   enabled: true
  #   target:
  #     username: me
  #   credential_refs:
  #     token: DOCENT_GITHUB_TOKEN
