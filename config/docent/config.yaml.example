# yaml-language-server: $schema=../../jsonschema/config.schema.json
# Unified docent config. Copy to ~/.config/docent/config.yaml and edit.
# Directives drive collectors; ai is optional (for future dashboard features).

# ai:
#   provider: ollama
#   ollama:
#     base_url: http://127.0.0.1:11434
#     model: qwen3

# open_trigger selects how the dashboard opens/focuses an editor window for a
# work item. Omit it entirely for no clickable open/focus links.
#   provider: cursor        # or: wsm
#   cursor:
#     command: cursor       # Cursor CLI binary
#     host: my-dev-box      # ssh alias for remote deep links (defaults to sshHost)
#     write_color: true     # sync work-item color into .vscode/settings.json (default true)
# open_trigger:
#   provider: wsm
#   wsm:
#     base_url: http://127.0.0.1:39788
#
# Listing live editor windows is a separate concern: declare a "cursor" or "wsm"
# collector directive below. (Session activity also arrives via the ingest API,
# POST /api/sessions/events.)

# sessions tunes the ingest registry's heartbeat-based liveness. A session is
# presumed dead once it is silent for heartbeat_interval * missed_heartbeats.
# sessions:
#   heartbeat_interval: 30s   # expected heartbeat cadence (default 30s)
#   missed_heartbeats: 2      # misses tolerated before a session is dead (default 2)

directives:
  - id: local-git-status
    name: git repo working trees
    collector: local-git
    enabled: true
    code_home: /Users/me/Code

  # - id: github-activity
  #   name: GitHub Activity
  #   collector: github
  #   enabled: true
  #   target:
  #     username: me
  #   credential_refs:
  #     token: DOCENT_GITHUB_TOKEN

  # Live editor windows via `cursor --status` (uncomment to enable):
  # - id: local-cursor
  #   name: Cursor sessions
  #   collector: cursor
  #   enabled: true
  #   config:
  #     machine: local
  #   state:
  #     poll:
  #       on_request: true
  #       on_load: true
